{
  "db_name": "MySQL",
  "query": "\n        SELECT\n            u.user_id,\n            u.name,\n            u.user_code,\n            u.password,\n            u.ban_flag,\n            CAST(\n                CASE\n                    WHEN EXISTS (\n                        SELECT 1\n                        FROM user_role ur\n                        WHERE ur.user_id = u.user_id\n                          AND ur.role_id IN ('admin', 'system')\n                    )\n                    THEN 1\n                    ELSE 0\n                END AS SIGNED\n            ) AS `role!: i64`\n        FROM user u\n        WHERE u.user_id = ?\n        ",
