# Database Configuration
# Copy this file to .env and update the values for your MariaDB setup

# MariaDB Connection Settings
DATABASE_URL=mysql://username:password@localhost:3306/arcaea_core

# Database Connection Details
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=username
DB_PASSWORD=password
DB_NAME=arcaea_core

# Optional: Connection Pool Settings
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1
DB_CONNECT_TIMEOUT=30
DB_IDLE_TIMEOUT=600

# Server Configuration
ROCKET_PORT=8090
ROCKET_ADDRESS=0.0.0.0
TITLE=Arcaea Server

# Core server config override order:
# .env/environment > Rocket.toml > built-in defaults.
# Rocket.toml uses snake_case keys, while .env uses the uppercase names below.
HOST=0.0.0.0
PORT=80
GAME_API_PREFIX=/coldwind/35
OLD_GAME_API_PREFIX=[]
ALLOW_APPVERSION=[]
BUNDLE_STRICT_MODE=true
WORLD_RANK_MAX=200
AVAILABLE_MAP=[]
USERNAME=admin
PASSWORD=admin
SECRET_KEY=1145141919810
API_TOKEN=
DOWNLOAD_USE_NGINX_X_ACCEL_REDIRECT=false
NGINX_X_ACCEL_REDIRECT_PREFIX=/nginx_download/
BUNDLE_NGINX_X_ACCEL_REDIRECT_PREFIX=/nginx_bundle_download/
DOWNLOAD_TIMES_LIMIT=3000
DOWNLOAD_TIME_GAP_LIMIT=1000
DOWNLOAD_FORBID_WHEN_NO_ITEM=false
BUNDLE_DOWNLOAD_TIMES_LIMIT=100/60 minutes
BUNDLE_DOWNLOAD_TIME_GAP_LIMIT=3000
GAME_REGISTER_IP_RATE_LIMIT=5/minute
GAME_REGISTER_DEVICE_RATE_LIMIT=5/minute
GAME_LOGIN_RATE_LIMIT=10/minute
LOGIN_DEVICE_NUMBER_LIMIT=1
ALLOW_LOGIN_SAME_DEVICE=false
ALLOW_BAN_MULTIDEVICE_USER_AUTO=true
ALLOW_SCORE_WITH_NO_SONG=true
DEFAULT_MEMORIES=0
UPDATE_WITH_NEW_CHARACTER_DATA=true
CHARACTER_FULL_UNLOCK=true
WORLD_SONG_FULL_UNLOCK=true
WORLD_SCENERY_FULL_UNLOCK=true
SAVE_FULL_UNLOCK=false
ALLOW_SELF_ACCOUNT_DELETE=false
BEST30_WEIGHT=0.025
RECENT10_WEIGHT=0.025
INVASION_START_WEIGHT=0.1
INVASION_HARD_WEIGHT=0.1
MAX_FRIEND_COUNT=50
ALLOW_INFO_LOG=false
ALLOW_WARNING_LOG=false
WORLD_MAP_FOLDER_PATH=./database/map/
SONG_FILE_FOLDER_PATH=./database/songs/
SONGLIST_FILE_PATH=./database/songs/songlist
CONTENT_BUNDLE_FOLDER_PATH=./database/bundle/
DATABASE_INIT_PATH=./database/init/

# Link Play Daemon Configuration (for `cargo run --bin linkplayd`)
LINKPLAY_HOST=0.0.0.0
LINKPLAY_UDP_PORT=10900
LINKPLAY_TCP_PORT=10901
LINKPLAY_DISPLAY_HOST=
LINKPLAY_DISPLAY_PORT=10900
LINKPLAY_AUTHENTICATION=my_link_play_server
LINKPLAY_TCP_SECRET_KEY=1145141919810
LINKPLAY_TCP_MAX_LENGTH=268435455
LINKPLAY_UNLOCK_LENGTH=1024
LINKPLAY_TIME_LIMIT_USEC=3600000000
LINKPLAY_COMMAND_INTERVAL_USEC=1000000
LINKPLAY_PLAYER_PRE_TIMEOUT_USEC=3000000
LINKPLAY_PLAYER_TIMEOUT_USEC=15000000
LINKPLAY_COUNTDOWN_SONG_READY_USEC=4000000
LINKPLAY_COUNTDOWN_SONG_START_USEC=6000000
LINKPLAY_COUNTDOWN_MATCHING_USEC=15000000
LINKPLAY_COUNTDOWN_SELECT_SONG_USEC=45000000
LINKPLAY_COUNTDOWN_SELECT_DIFFICULTY_USEC=45000000
LINKPLAY_COUNTDOWN_RESULT_USEC=60000000
LINKPLAY_CLEANUP_INTERVAL_SEC=15

# Security Settings (generate strong random strings)
JWT_SECRET=your-super-secret-jwt-key-here
ENCRYPTION_KEY=your-encryption-key-here

# Feature Flags
ALLOW_SELF_ACCOUNT_DELETE=false
EMAIL_VERIFICATION_ENABLED=false

# Runtime asset root (maps, packs, singles, courses, arc_data)
# Default: ./assets
ASSET_DIR=

# arc_data file used by both `init_db` and server startup sync
# Default path when empty: $ASSET_DIR/arc_data.json
ARC_DATA_FILE=

# Logging
RUST_LOG=info

# Optional public URL prefixes (for reverse proxy / CDN)
# Example:
# DOWNLOAD_LINK_PREFIX=https://arc.yinmo.site/download/
# BUNDLE_DOWNLOAD_LINK_PREFIX=https://arc.yinmo.site/bundle_download/
DOWNLOAD_LINK_PREFIX=
BUNDLE_DOWNLOAD_LINK_PREFIX=

# Asset file storage backend.
# local: scan ./songs and ./bundles, then serve files through this server.
# s3: load S3_MANIFEST_KEY at startup/cache refresh and return S3 presigned URLs.
STORAGE_BACKEND=local

# S3-compatible storage settings. MinIO example:
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_REGION=us-east-1
# S3_BUCKET=arcaea-assets
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_FORCE_PATH_STYLE=true
# S3_MANIFEST_KEY=manifest.json
# S3_PRESIGN_EXPIRES_SECONDS=3600
# S3_METADATA_SYNC_INTERVAL_SECONDS=180
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
S3_MANIFEST_KEY=manifest.json
S3_PRESIGN_EXPIRES_SECONDS=3600
S3_METADATA_SYNC_INTERVAL_SECONDS=180

# Optional defaults for `cargo run --bin sync_s3_manifest -- sync`
S3_SYNC_SONGS_DIR=songs
S3_SYNC_BUNDLES_DIR=bundles
S3_SYNC_SONG_LIMIT=
S3_SYNC_SKIP_CREATE_BUCKET=false

# Optional Redis cache. Leave REDIS_URL empty to disable caching.
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL=
REDIS_KEY_PREFIX=arcaea
REDIS_AUTH_TTL_SECONDS=86400
REDIS_USER_INFO_TTL_SECONDS=2
REDIS_SCORE_TOP_TTL_SECONDS=3
REDIS_SCORE_USER_TTL_SECONDS=2
REDIS_SCORE_FRIEND_TTL_SECONDS=2
REDIS_SCORE_POTENTIAL_TTL_SECONDS=5
REDIS_USER_RATING_TTL_SECONDS=5
REDIS_GLOBAL_RANK_TTL_SECONDS=10
REDIS_USER_DETAIL_TTL_SECONDS=15
REDIS_ZSET_RANK_TTL_SECONDS=300
REDIS_FRIEND_TTL_SECONDS=5
REDIS_PURCHASE_TTL_SECONDS=10
REDIS_WORLD_TTL_SECONDS=2
REDIS_PRESIGN_TTL_SECONDS=300
REDIS_DOWNLOAD_LIST_TTL_SECONDS=30
