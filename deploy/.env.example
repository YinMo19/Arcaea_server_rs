# Copy to deploy/.env before running docker compose.

HTTP_PORT=8080

# Production Caddy TLS settings. Use docker-compose.prod.yml to publish 80/443.
# CADDY_TLS_MODE=https uses Caddyfile.https and normal automatic certificates.
# CADDY_TLS_MODE=dns uses Caddyfile.dns. For Cloudflare DNS challenge also set
# CADDY_BUILD_TARGET=caddy-cloudflare and CLOUDFLARE_API_TOKEN.
CADDY_BUILD_TARGET=caddy
CADDY_TLS_MODE=https
SITE_DOMAIN=example.com
ACME_EMAIL=admin@example.com
CLOUDFLARE_API_TOKEN=

MARIADB_ROOT_PASSWORD=change-me-root
MARIADB_DATABASE=arcaea_core
MARIADB_USER=arcaea
MARIADB_PASSWORD=change-me-db
MARIADB_PUBLISHED_PORT=3306

DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=1

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
SERVER_USERNAME=admin
SERVER_PASSWORD=admin
SECRET_KEY=change-me-secret-key
API_TOKEN=
RUST_LOG=info
RUN_DB_INIT=true
DISABLE_REGISTRATION=false
TRACE_COMPLETE_TICKET_REWARD_ENABLED=false

# Link Play. Set LINKPLAY_DISPLAY_HOST to your public IP/domain in production.
LINKPLAY_DISPLAY_HOST=127.0.0.1
LINKPLAY_UDP_PORT=10900
LINKPLAY_TCP_PORT=10901
LINKPLAY_UDP_PUBLISHED_PORT=10900
LINKPLAY_TCP_PUBLISHED_PORT=10901
LINKPLAY_AUTHENTICATION=my_link_play_server
LINKPLAY_TCP_SECRET_KEY=change-me-linkplay-secret
LINKPLAY_UNLOCK_LENGTH=1024

# local: read ./songs and ./bundles bind mounts.
# s3: read S3_MANIFEST_KEY and return presigned URLs.
STORAGE_BACKEND=local

# Optional S3/MinIO settings. Enable with:
# docker compose --profile s3 up -d minio
# docker compose --profile s3 run --rm s3-sync sync
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=arcaea-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_MANIFEST_KEY=manifest.json
S3_PRESIGN_EXPIRES_SECONDS=3600
S3_METADATA_SYNC_INTERVAL_SECONDS=180
S3_SYNC_SKIP_CREATE_BUCKET=false

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_TAG=latest
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

REDIS_KEY_PREFIX=arcaea

# Optional reverse-proxy/CDN URL prefixes.
DOWNLOAD_LINK_PREFIX=
BUNDLE_DOWNLOAD_LINK_PREFIX=null
